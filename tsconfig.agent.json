{
  "extends": ["./tsconfig.base.json"],
  "include": ["src/agent/*.ts", "src/types/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.mock.ts"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.agent.tsbuildinfo",
    "rootDir": "src",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "module": "esnext",
    "lib": ["ES2024", "DOM", "DOM.Iterable"]
  }
}
