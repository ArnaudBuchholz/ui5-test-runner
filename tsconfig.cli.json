{
  "extends": ["./tsconfig.base.json"],
  "include": ["src/"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.mock.ts", "src/agent/**", "src/ui/**", "src/**/ui/**", "src/ai/**"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.cli.tsbuildinfo",
    "rootDir": "src",
    "types": ["node"],
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "module": "esnext"
  }
}
