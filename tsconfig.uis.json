{
  "extends": ["./tsconfig.base.json"],
  "include": [
    "src/css.d.ts",
    "src/ui/**/*.ts",
    "src/**/ui/**/*.ts",
    "src/ai/**/*.ts",
    "src/types/*.ts",
    "src/modes/log/ui/*.ts",
    "src/modes/log/LogMetrics.ts",
    "src/modes/log/ILogStorage.ts",
    "src/platform/logger/types.ts",
    "src/utils/**/*.ts"
  ],
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true
  }
}
